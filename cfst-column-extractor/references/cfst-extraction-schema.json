{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cfst-extraction-schema.json",
  "title": "CFST Column Ultimate Load Capacity Extraction Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "paper",
    "section_groups"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "paper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_info",
        "validity",
        "paper_evidence"
      ],
      "properties": {
        "ref_info": {
          "$ref": "#/$defs/ref_info"
        },
        "validity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "is_valid",
            "reason"
          ],
          "properties": {
            "is_valid": {
              "type": "boolean"
            },
            "reason": {
              "type": [
                "string",
                "null"
              ],
              "description": "Required when is_valid is false; briefly state why no in-scope data can be extracted."
            }
          }
        },
        "paper_evidence": {
          "$ref": "#/$defs/evidence_block",
          "description": "Paper-level evidence shared by many or all specimen rows, such as data table captions, global test setup description, or global material-test basis."
        },
        "paper_shared_defaults": {
          "$ref": "#/$defs/shared_defaults",
          "description": "Defaults shared across all section groups when applicable. Section-group shared fields and specimen fields override these values."
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "section_groups": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "square",
        "rectangular",
        "circular",
        "round_ended"
      ],
      "properties": {
        "square": {
          "$ref": "#/$defs/section_group"
        },
        "rectangular": {
          "$ref": "#/$defs/section_group"
        },
        "circular": {
          "$ref": "#/$defs/section_group"
        },
        "round_ended": {
          "$ref": "#/$defs/section_group"
        }
      }
    }
  },
  "$defs": {
    "ref_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "authors",
        "journal",
        "year",
        "doi",
        "language"
      ],
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "journal": {
          "type": [
            "string",
            "null"
          ]
        },
        "year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1800,
          "maximum": 2100
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ],
          "description": "Use common language tags such as zh, en, ja, ko, de, fr, or null when unknown."
        }
      }
    },
    "section_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_data",
        "shared",
        "specimens"
      ],
      "properties": {
        "has_data": {
          "type": "boolean"
        },
        "shared": {
          "$ref": "#/$defs/shared_defaults",
          "description": "Values and evidence shared by specimens in this section-shape group. Specimen-level fields override these values."
        },
        "specimens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/specimen"
          }
        },
        "group_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "shared_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "data": {
          "$ref": "#/$defs/extraction_data",
          "description": "Shared extracted values. These may be incomplete; missing values are expected to be filled at a lower level or left absent when not shared."
        },
        "evidence": {
          "$ref": "#/$defs/evidence_block",
          "description": "Evidence and derivation notes for shared extracted values. Specimen-level evidence overrides or supplements this block."
        }
      }
    },
    "specimen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specimen_id",
        "data"
      ],
      "properties": {
        "specimen_id": {
          "type": "string",
          "description": "Specimen label exactly as given in the source."
        },
        "data": {
          "$ref": "#/$defs/extraction_data",
          "description": "Specimen-specific extracted values. Any value here overrides paper-level or section-group shared defaults."
        },
        "evidence": {
          "$ref": "#/$defs/evidence_block",
          "description": "Specimen-specific evidence or derivation notes. Use only when the specimen differs from shared evidence or needs specific traceability."
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reported_group_average",
              "figure_derived",
              "formula_derived",
              "text_derived",
              "table_derived",
              "ambiguous_source",
              "unit_converted",
              "partially_unknown"
            ]
          },
          "uniqueItems": true
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "extraction_data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fco_mpa": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "fc_type": {
          "type": "string",
          "pattern": "^(cube|cube_[0-9]+|cylinder|cylinder_[0-9]+x[0-9]+|prism|prism_[0-9]+x[0-9]+x[0-9]+|unknown|[A-Za-z0-9_\\-x]+)$"
        },
        "fy_mpa": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "recycled_aggregate_ratio_percent": {
          "$ref": "#/$defs/percent_number"
        },
        "geometry": {
          "$ref": "#/$defs/geometry"
        },
        "eccentricity": {
          "$ref": "#/$defs/eccentricity"
        },
        "n_exp_kn": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "material": {
          "$ref": "#/$defs/material"
        },
        "loading_mode": {
          "$ref": "#/$defs/loading_mode"
        },
        "condition": {
          "$ref": "#/$defs/condition"
        }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "b_mm": {
          "$ref": "#/$defs/nonnegative_number",
          "description": "Outer width; for circular sections b = h = outer diameter D; for rectangular sections b >= h."
        },
        "h_mm": {
          "$ref": "#/$defs/nonnegative_number",
          "description": "Outer depth or height."
        },
        "t_mm": {
          "$ref": "#/$defs/nonnegative_number",
          "description": "Steel tube wall thickness."
        },
        "r0_mm": {
          "$ref": "#/$defs/nonnegative_number",
          "description": "Outer corner radius. Square/rectangular sections generally use 0 unless rounded corners are reported; circular and round-ended sections use h/2."
        },
        "l_mm": {
          "$ref": "#/$defs/nonnegative_number",
          "description": "Project geometric specimen length. Use direct length first, then clear formula/ratio, then clear figure-derived geometric length."
        }
      }
    },
    "eccentricity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "e1_mm": {
          "type": "number",
          "description": "Signed upper-end eccentricity; 0 for axial loading."
        },
        "e2_mm": {
          "type": "number",
          "description": "Signed lower-end eccentricity; 0 for axial loading."
        },
        "top_components_mm": {
          "$ref": "#/$defs/eccentricity_components"
        },
        "bottom_components_mm": {
          "$ref": "#/$defs/eccentricity_components"
        }
      }
    },
    "eccentricity_components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": [
            "number",
            "null"
          ]
        },
        "y": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steel": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "carbon_steel",
                "stainless_steel",
                "other"
              ]
            },
            "note": {
              "type": [
                "string",
                "null"
              ],
              "description": "Required when type is other."
            }
          }
        },
        "concrete": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "normal",
                "UHPC",
                "recycled_concrete",
                "other"
              ]
            },
            "note": {
              "type": [
                "string",
                "null"
              ],
              "description": "Required when type is other."
            }
          }
        }
      }
    },
    "loading_mode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "monotonic",
            "cyclic",
            "sustained",
            "dynamic",
            "thermal",
            "other"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Required when type is other; optional otherwise."
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tags"
      ],
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "normal",
              "corrosion",
              "freeze_thaw",
              "thermal",
              "long_term",
              "defect",
              "damage",
              "strengthened",
              "other"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Required when tags contains other; optional otherwise."
        }
      }
    },
    "evidence_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_locations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_location"
          },
          "description": "Tables, figures, sections, or original source text supporting the extracted values. Page numbers are optional and should not be the only evidence locator."
        },
        "field_evidence": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/field_evidence"
          },
          "description": "Keyed by field path such as fco_mpa, fc_type, geometry.l_mm, geometry.r0_mm, eccentricity.e1_mm, n_exp_kn, material, loading_mode, or condition."
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "description": "General traceability note for this paper, group, or specimen."
        }
      }
    },
    "source_location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "table": {
          "type": [
            "string",
            "null"
          ]
        },
        "figure": {
          "type": [
            "string",
            "null"
          ]
        },
        "section": {
          "type": [
            "string",
            "null"
          ]
        },
        "quote": {
          "type": [
            "string",
            "null"
          ],
          "description": "Original source text, formula text, table heading, or relevant caption. Prefer quotes/table identifiers over page-only evidence."
        }
      }
    },
    "field_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_locations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_location"
          }
        },
        "basis": {
          "type": [
            "string",
            "null"
          ],
          "description": "How this field was obtained, such as directly reported, unit converted, formula-derived, figure-derived, inferred from table heading, or inherited from shared context."
        },
        "derivation": {
          "type": [
            "string",
            "null"
          ],
          "description": "Calculation or reasoning details, e.g. L from figure clear height, r0 = h/2, or fc_type inferred from cube size statement."
        },
        "raw_value": {
          "type": [
            "string",
            "number",
            "null"
          ],
          "description": "Original value before normalization when useful for traceability."
        },
        "normalized_value": {
          "type": [
            "string",
            "number",
            "null"
          ],
          "description": "Stored normalized value when useful for traceability."
        }
      }
    },
    "nonnegative_number": {
      "type": "number",
      "minimum": 0
    },
    "percent_number": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
